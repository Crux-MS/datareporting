	partition Client = m
		mode: import
		source =
				let
				    Source = #"Clients - Source",
				    #"Removed Other Columns" = Table.SelectColumns(Source,{"ClientId", "FirstName", "MiddleName", "LastName", "FundingType", "DateOfBirth", "Area", "Division", "ServiceStatus", "ServiceStart", "ServiceEnd"}),
				    #"Merged Columns" = Table.CombineColumns(#"Removed Other Columns",{"FirstName", "MiddleName", "LastName"},Combiner.CombineTextByDelimiter(" ", QuoteStyle.None),"FullName"),
				    #"Replaced Value" = Table.ReplaceValue(#"Merged Columns","0000-00-00",null,Replacer.ReplaceValue,{"ServiceEnd", "ServiceStart", "DateOfBirth"}),
