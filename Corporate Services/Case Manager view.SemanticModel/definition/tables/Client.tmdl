table Client
	lineageTag: cea5b36e-9cb8-422e-badc-49dbf3c07ca2

	measure ClientAge = CALCULATE(DATEDIFF(SELECTEDVALUE('Client'[DateOfBirth]), NOW(), YEAR), CROSSFILTER('Client'[ClientId], 'DimClientCaseManager'[ClientId], Both))
		formatString: 0
		lineageTag: b84178bc-facf-418b-82c6-e90119e10f8a

	measure ChildAdultFlag = IF([ClientAge] < 18, "Child", "Adult")
		lineageTag: 9b12e37b-09c5-466c-b2b5-c7f4e721e1a3

	measure SelectedClientName =
			VAR _singleSelection = HASONEVALUE('Client'[FullName])
			VAR _logic = IF(_singleSelection, CALCULATE(SELECTEDVALUE('Client'[FullName]), CROSSFILTER('Client'[ClientId], 'DimClientCaseManager'[ClientId], Both)), BLANK())
			RETURN _logic
		lineageTag: 65050a96-d7f7-4427-871d-12d547a95ba7

	measure ShowClientDetails = INT(ISFILTERED('Client'[FullName]))
		formatString: 0
		lineageTag: ceb46cc1-b18a-4c51-bdbd-eaec9c1cdf33

	column ClientId
		dataType: int64
		formatString: 0
		lineageTag: bc046225-9a54-4b95-9f00-47413b58dc44
